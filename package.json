{
  "name": "flash-token-system",
  "version": "1.0.0",
  "description": "Flash token system for Ethereum and Bitcoin (Stacks) - tokens appear in wallet but cannot be spent, only gas fees allowed",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd frontend && npm install",
    "dev:contracts": "hardhat node",
    "compile": "hardhat compile",
    "deploy:ethereum": "hardhat run scripts/deployFlashToken.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deployFlashToken.js --network sepolia",
    "test": "hardhat test",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [
    "ethereum",
    "stacks",
    "bitcoin",
    "flash-tokens",
    "smart-contracts",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "@openzeppelin/contracts": "^5.0.0",
    "@typechain/ethers-v6": "^0.4.3",
    "@typechain/hardhat": "^8.0.3",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.4",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  }
}
