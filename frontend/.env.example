# Mainnet RPC (Infura)
VITE_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_API_KEY

# Fake Token Contracts (Mainnet)
VITE_FAKE_BTC_ADDRESS=0x...
VITE_FAKE_ETH_ADDRESS=0x...

# WalletConnect (Optional - for mobile wallet support)
# Get Project ID at: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# API Configuration (Optional)
VITE_API_URL=http://localhost:5000

# Environment
VITE_ENV=production
